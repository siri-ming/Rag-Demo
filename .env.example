# 百炼（阿里云 DashScope）API Key（必填）
# 从 https://bailian.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=your-api-key-here
# 对话模型（qwen-plus 性价比高，适合开发测试）
DASHSCOPE_LLM_MODEL=qwen-plus
# Embedding 模型（text-embedding-v3 默认输出 1024 维向量）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# DashScope OpenAI 兼容接口地址（一般无需修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PostgreSQL 数据库连接（需安装 pgvector 扩展）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db
# 向量维度（需与 Embedding 模型一致，text-embedding-v3 默认 1024）
EMBEDDING_DIM=1024
# 上传目录
UPLOAD_DIR=./uploads
